
import { useState } from "react";
import { Card, CardContent } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";

export default function App() {
  const [habits, setHabits] = useState([]);
  const [newHabit, setNewHabit] = useState("");

  const addHabit = () => {
    if (!newHabit) return;
    setHabits([...habits, { name: newHabit, done: false }]);
    setNewHabit("");
  };

  const toggleHabit = (index) => {
    const updated = [...habits];
    updated[index].done = !updated[index].done;
    setHabits(updated);
  };

  return (
    <div className="p-6 max-w-xl mx-auto">
      <h1 className="text-2xl font-bold mb-4">Daily Habit Builder</h1>

      <div className="flex gap-2 mb-4">
        <Input
          placeholder="Add a habit..."
          value={newHabit}
          onChange={(e) => setNewHabit(e.target.value)}
        />
        <Button onClick={addHabit}>Add</Button>
      </div>

      <div className="grid gap-3">
        {habits.map((habit, i) => (
          <Card key={i} className="cursor-pointer" onClick={() => toggleHabit(i)}>
            <CardContent className="p-4 flex justify-between">
              <span>{habit.name}</span>
              <span>{habit.done ? "✅" : "⬜"}</span>
            </CardContent>
          </Card>
        ))}
      </div>

      <div className="mt-6 text-sm text-gray-500">
        Monetization idea: Freemium model with premium analytics, reminders, and streak tracking.
      </div>
    </div>
  );
}
